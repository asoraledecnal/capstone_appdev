{
  "database_schema": {
    "description": "Firestore Schema for Sentinel IV-A (DICT-4A pfSense & Heuristic Threat Logs) - Fully RA 10173 Compliant",
    "collections": {
      "spokes": {
        "description": "Metadata for pfSense branch firewall endpoints (spokes). Restricted to passive operational metadata; contains absolutely no PII, staff names, personal emails, or telephone numbers.",
        "fields": {
          "spoke_id": {
            "type": "String",
            "constraints": "Document ID (Primary Key). Format: SPOKE-XX",
            "description": "Unique identifier for the branch pfSense firewall gateway."
          },
          "office_name": {
            "type": "String",
            "constraints": "Non-null",
            "description": "Official name of the DICT branch or provincial office."
          },
          "location": {
            "type": "String",
            "constraints": "Non-null",
            "description": "General municipal or city location of the office."
          },
          "public_ip_mask": {
            "type": "String",
            "constraints": "Masked format to comply with security standards",
            "description": "Masked gateway public IP (e.g., 112.204.XX.XX) to prevent exposing precise network topologies."
          },
          "pfsense_version": {
            "type": "String",
            "constraints": "Non-null",
            "description": "Active pfSense software version installed on the gateway."
          },
          "status": {
            "type": "String",
            "constraints": "Enum: ['Online', 'Offline']",
            "description": "Current real-time connectivity status of the IPsec VPN tunnel."
          },
          "contact_role": {
            "type": "String",
            "constraints": "Role-based/Anonymous",
            "description": "Responsible role designation (e.g., 'Lead Security Analyst Group A') rather than specific human names, satisfying RA 10173 data minimization principles."
          }
        }
      },
      "incidents": {
        "description": "Heuristic threat logs generated by behavioral anomalies. Restricted strictly to metadata. Absolutely no PII, user session credentials, raw payload packets, or AI/ML generated data.",
        "fields": {
          "incident_id": {
            "type": "String",
            "constraints": "Document ID (Primary Key). Format: INC-YYYYMMDD-XXX",
            "description": "Unique behavioral log identifier."
          },
          "timestamp": {
            "type": "String",
            "constraints": "ISO 8601 UTC timestamp",
            "description": "Precise timing of log detection."
          },
          "spoke_id": {
            "type": "String",
            "constraints": "Foreign Key referencing spokes.spoke_id",
            "description": "Identifier of the pfSense spoke endpoint triggering the anomaly."
          },
          "alert_type": {
            "type": "String",
            "constraints": "Enum: ['High Latency', 'IPsec Tunnel Down', 'Port Scan Detected', 'Brute Force Attempt', 'DDoS Heuristic Threat', 'Gateway Connectivity Alert']",
            "description": "Behavioral threat alert category."
          },
          "severity": {
            "type": "String",
            "constraints": "Enum: ['Low', 'Medium', 'High', 'Critical']",
            "description": "Risk urgency and operational priority."
          },
          "ticket_status": {
            "type": "String",
            "constraints": "Enum: ['Open', 'Investigating', 'Resolved', 'Mitigated']",
            "description": "Remediation lifecycle state."
          }
        }
      }
    }
  },
  "relationship_mapping": {
    "type": "One-to-Many (1:N)",
    "description": "Each spoke pfSense firewall can be the source of multiple security incidents. An incident is mapped to its parent spoke using the spoke_id field as a foreign key reference.",
    "diagram_ascii": " [spokes collection]                         [incidents collection]       \n+-----------------------+                    +----------------------------+\n| spoke_id (PK)         | <----------------- | spoke_id (FK)              |\n| office_name           |    One-to-Many     | incident_id (PK)           |\n| location              |       (1:N)        | timestamp                  |\n| public_ip_mask        |                    | alert_type                 |\n| pfsense_version       |                    | severity                   |\n| status                |                    | ticket_status              |\n| contact_role          |                    +----------------------------+\n+-----------------------+"
  },
