rules_version = '2';

// DICT-4A Wazuh SIEM — Firestore Security Rules
//
// Principle: only authenticated users may read or write any data.
// No anonymous or unauthenticated access is permitted.
//
// Deploy with:
//   firebase deploy --only firestore:rules
//
// Future hardening (post-capstone):
//   - Scope writes to admin-role users only (store role in users/{uid})
//   - Scope spoke reads by the user's assigned spokeId from their profile
//   - Add field-level validation (e.g. severity must be LOW/MEDIUM/HIGH/CRITICAL)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    /// Returns true only if the request comes from a signed-in user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Collections ─────────────────────────────────────────────────────────

    // User profiles — a user may only read/write their own document.
    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Wazuh agents — any authenticated user may read; no client-side writes.
    match /wazuh_agents/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // agents are written by the Wazuh server only
    }

    // Wazuh events — any authenticated user may read; no client-side writes.
    match /wazuh_events/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // events are ingested server-side only
    }

    // Incidents — authenticated users may read and write (CRUD from the UI).
    match /incidents/{docId} {
      allow read, write: if isAuthenticated();
    }

    // CVE findings — read-only for authenticated users.
    match /cve_findings/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // IOC findings — read-only for authenticated users.
    match /ioc_findings/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // File integrity events — read-only for authenticated users.
    match /file_integrity_events/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Compliance records — read-only for authenticated users.
    match /compliance_records/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // MITRE ATT&CK tactics — read-only for authenticated users.
    match /mitre_tactics/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
